# Frontend API base URL (must include /api)
# Local:
# VITE_API_URL=http://localhost:5000/api
# Production example:
# VITE_API_URL=https://your-backend-domain.com/api
VITE_API_URL=http://localhost:5000/api

# Optional Socket.IO URL (backend origin, no /api)
# If omitted, frontend derives it from VITE_API_URL.
# Local:
# VITE_SOCKET_URL=http://localhost:5000
# Production example:
# VITE_SOCKET_URL=https://your-backend-domain.com
VITE_SOCKET_URL=http://localhost:5000
